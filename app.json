{
  "expo": {
    "name": "AA Mods",
    "slug": "aa-mods-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aa-mods",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#00e673",
      "androidMode": "default",
      "androidCollapsedTitle": "AA Mods"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aa.mods"
    },
    "android": {
      "package": "com.aa.mods",
      "backgroundColor": "#050816",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050816"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://aa-mods.vercel.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00e673",
          "defaultChannel": "aa-mods-updates",
          "sounds": []
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": ["./assets/images/notification-icon.png"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "734dbcb5-e59a-4f2d-afc9-b5596a0a30da"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "ahsanali12"
  }
}
