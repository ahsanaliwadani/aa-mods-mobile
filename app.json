{
  "expo": {
    "name": "AA Mods",
    "slug": "aa-mods-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aa-mods",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#00e673",
      "androidMode": "default",
      "androidCollapsedTitle": "AA Mods"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aa.mods",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.aa.mods",
      "versionCode": 2,
      "backgroundColor": "#050816",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050816"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.REQUEST_INSTALL_PACKAGES",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://aa-mods.vercel.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00e673",
          "defaultChannel": "aa-mods-updates",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": [
            "./assets/images/notification-icon.png"
          ],
          "largeIcons": [
            "./assets/images/notification-icon.png"
          ]
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7386485617389952~7325371535",
          "iosAppId": "ca-app-pub-7386485617389952~7325371535",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
          "skAdNetworkItems": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a3b800a2-d974-4517-aebc-7ed2089c3746"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "ahsanwadani"
  }
}
